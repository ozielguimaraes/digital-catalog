<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:home="clr-namespace:MeuCatalogo.Features.Home"
             xmlns:catalogo="clr-namespace:MeuCatalogo.Features.Catalogo"
             xmlns:domain="clr-namespace:MeuCatalogo.Features.Produto.Domain"
             x:Class="MeuCatalogo.Features.Home.HomePage"
             x:Name="HomePageRoot"
             x:DataType="home:HomePageViewModel">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            BindingContext="{Binding Source={x:Reference HomePageRoot}, Path=BindingContext}"
            EventName="Appearing"
            Command="{Binding CarregarCommand}" />
    </ContentPage.Behaviors>

    <RefreshView Command="{Binding CarregarCommand}" IsRefreshing="{Binding IsRefreshing}">
        <ScrollView>
            <VerticalStackLayout Padding="0" Spacing="0">

                <!-- Hero greeting -->
                <Border Style="{StaticResource Hero}" HeightRequest="220">
                    <Grid Padding="24,52,24,24" RowDefinitions="Auto,*,Auto">
                        <Label Grid.Row="0"
                               Text="SANY&amp;Z · ATELIÊ"
                               FontFamily="LatoBlack"
                               FontSize="11"
                               CharacterSpacing="6"
                               TextColor="{StaticResource OnPrimaryColor}"
                               Opacity="0.85" />
                        <VerticalStackLayout Grid.Row="1" VerticalOptions="End" Spacing="0">
                            <Label Text="{Binding Saudacao, StringFormat='{0},'}"
                                   FontFamily="LoraMediumItalic"
                                   FontSize="22"
                                   TextColor="{StaticResource OnPrimaryColor}" />
                            <Label Text="{Binding NomeUsuario}"
                                   FontFamily="LoraSemiBold"
                                   FontSize="32"
                                   TextColor="{StaticResource OnPrimaryColor}"
                                   LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>
                        <Label Grid.Row="2"
                               Text="LEVE COM VOCÊ"
                               FontFamily="LatoBold"
                               FontSize="10"
                               CharacterSpacing="4"
                               TextColor="{StaticResource OnPrimaryColor}"
                               Opacity="0.75"
                               Margin="0,12,0,0" />
                    </Grid>
                </Border>

                <VerticalStackLayout Padding="20,-32,20,32" Spacing="14">

                    <!-- Stats -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border Grid.Column="0" Style="{StaticResource CardElevated}" Padding="18">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding VerCatalogosCommand}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="6">
                                <Label Style="{StaticResource Caps}" Text="CATÁLOGOS" />
                                <Label Style="{StaticResource SerifH1}"
                                       FontSize="36"
                                       Text="{Binding TotalCatalogos}" />
                                <Label Style="{StaticResource BodyMuted}" Text="ativos" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource CardElevated}" Padding="18">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding VerProdutosCommand}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="6">
                                <Label Style="{StaticResource Caps}" Text="PRODUTOS" />
                                <Label Style="{StaticResource SerifH1}"
                                       FontSize="36"
                                       Text="{Binding TotalProdutos}" />
                                <Label Style="{StaticResource BodyMuted}"
                                       Text="{Binding CatalogoFavoritoNome, StringFormat='em {0}'}"
                                       LineBreakMode="TailTruncation"
                                       IsVisible="{Binding TemCatalogoFavorito}" />
                                <Label Style="{StaticResource BodyMuted}"
                                       Text="sem catálogo favorito"
                                       IsVisible="{Binding TemCatalogoFavorito, Converter={toolkit:InvertedBoolConverter}}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Quick actions -->
                    <Border Style="{StaticResource Card}" Padding="20">
                        <VerticalStackLayout Spacing="12">
                            <Label Style="{StaticResource Caps}" Text="ATALHOS" />
                            <Label Style="{StaticResource SerifH3}" Text="Adicionar" Margin="0,-2,0,0" />

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Button Grid.Column="0"
                                        Style="{StaticResource PrimaryButton}"
                                        Text="NOVO PRODUTO"
                                        FontSize="12"
                                        Padding="14,12"
                                        Command="{Binding NovoProdutoCommand}" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource SecondaryButton}"
                                        Text="NOVO CATÁLOGO"
                                        FontSize="12"
                                        Padding="14,12"
                                        Command="{Binding NovoCatalogoCommand}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Produtos recentes -->
                    <VerticalStackLayout Spacing="10" IsVisible="{Binding TemProdutosRecentes}">
                        <Grid ColumnDefinitions="*,Auto" Margin="4,8,4,0">
                            <Label Grid.Column="0" Style="{StaticResource Caps}" Text="RECENTES" VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="VER TODOS"
                                   Style="{StaticResource CapsPrimary}"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding VerProdutosCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                        <CollectionView ItemsSource="{Binding ProdutosRecentes}"
                                        HeightRequest="220"
                                        SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="domain:ProdutoEntity">
                                    <Border Style="{StaticResource CardElevated}"
                                            Padding="0"
                                            WidthRequest="160">
                                        <VerticalStackLayout Spacing="0">
                                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceMutedColorLight}, Dark={StaticResource SurfaceMutedColorDark}}"
                                                    StrokeThickness="0"
                                                    HeightRequest="120"
                                                    IsClippedToBounds="True">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="18,18,0,0" />
                                                </Border.StrokeShape>
                                                <Image Aspect="AspectFill"
                                                       IsVisible="{Binding ThumbnailUrl, Converter={x:Static catalogo:NotNullOrEmptyConverter.Instance}}">
                                                    <Image.Source>
                                                        <UriImageSource Uri="{Binding ThumbnailUrl}" CacheValidity="1.00:00:00" />
                                                    </Image.Source>
                                                </Image>
                                            </Border>
                                            <VerticalStackLayout Padding="12,10" Spacing="4">
                                                <Label Style="{StaticResource SerifH3}"
                                                       FontSize="15"
                                                       Text="{Binding Nome}"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="2" />
                                                <Label Text="{Binding Preco, StringFormat='{0:C}'}"
                                                       FontFamily="LatoBold"
                                                       FontSize="13"
                                                       TextColor="{AppThemeBinding Light={StaticResource PrimaryHoverColorLight}, Dark={StaticResource PrimaryColorDark}}" />
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <!-- Empty -->
                    <Border Style="{StaticResource Card}"
                            Padding="24"
                            IsVisible="{Binding TemProdutosRecentes, Converter={toolkit:InvertedBoolConverter}}">
                        <VerticalStackLayout Spacing="6">
                            <Label Style="{StaticResource SerifH3}" Text="Pronto pra começar?" />
                            <Label Style="{StaticResource BodyMuted}"
                                   Text="Crie um catálogo e seus primeiros produtos para vê-los aqui." />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
