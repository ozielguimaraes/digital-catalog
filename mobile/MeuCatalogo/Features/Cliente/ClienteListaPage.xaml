<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:cliente="clr-namespace:MeuCatalogo.Features.Cliente"
             xmlns:domain="clr-namespace:MeuCatalogo.Features.Cliente.Domain"
             x:Class="MeuCatalogo.Features.Cliente.ClienteListaPage"
             x:Name="ClienteListaPageRoot"
             x:DataType="cliente:ClienteListaPageViewModel"
             Shell.NavBarIsVisible="False">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            BindingContext="{Binding Source={x:Reference ClienteListaPageRoot}, Path=BindingContext}"
            EventName="Appearing"
            Command="{Binding CarregarCommand}" />
    </ContentPage.Behaviors>

    <Grid RowDefinitions="Auto,*">

        <VerticalStackLayout Grid.Row="0" Padding="24,48,24,12" Spacing="6">
            <Grid ColumnDefinitions="40,*,40">
                <Border Grid.Column="0"
                        Style="{StaticResource IconCircleSurface}"
                        HeightRequest="40"
                        WidthRequest="40">
                    <Label Text="‹"
                           FontSize="22"
                           FontFamily="LoraMedium"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding VoltarCommand}" />
                    </Border.GestureRecognizers>
                </Border>
            </Grid>
            <Label Style="{StaticResource Caps}" Text="ATELIÊ · CRM" />
            <Label Style="{StaticResource SerifH1}" Text="Clientes" />
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <Grid Padding="24,8,24,32" RowDefinitions="Auto,Auto">

                <VerticalStackLayout Grid.Row="0"
                                     IsVisible="{Binding IsLoading}"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Padding="0,48"
                                     Spacing="12">
                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                                       WidthRequest="36"
                                       HeightRequest="36" />
                    <Label Style="{StaticResource BodyMuted}"
                           HorizontalTextAlignment="Center"
                           Text="Carregando clientes…" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="0"
                                     IsVisible="{Binding ShowEmptyState}"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Padding="0,48"
                                     Spacing="12">
                    <Border Style="{StaticResource IconCircleSurface}"
                            HeightRequest="92"
                            WidthRequest="92"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="46" />
                        </Border.StrokeShape>
                        <Label Text="✦"
                               FontFamily="LoraMedium"
                               FontSize="32"
                               TextColor="{AppThemeBinding Light={StaticResource PrimaryColorLight}, Dark={StaticResource PrimaryColorDark}}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <Label Style="{StaticResource SerifH2}"
                           HorizontalTextAlignment="Center"
                           Text="Nenhum cliente cadastrado" />
                    <Label Style="{StaticResource BodyMuted}"
                           HorizontalTextAlignment="Center"
                           Text="Os clientes aparecem aqui assim que forem cadastrados." />
                </VerticalStackLayout>

                <CollectionView Grid.Row="1"
                                ItemsSource="{Binding Clientes}"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="domain:ClienteInfo">
                            <Border Style="{StaticResource CardElevated}" Padding="16">
                                <Grid ColumnDefinitions="48,*" ColumnSpacing="14">
                                    <Border Grid.Column="0"
                                            Style="{StaticResource IconCircleSurface}"
                                            HeightRequest="48"
                                            WidthRequest="48"
                                            VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="24" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding Iniciais}"
                                               FontFamily="LoraSemiBold"
                                               FontSize="16"
                                               TextColor="{AppThemeBinding Light={StaticResource PrimaryHoverColorLight}, Dark={StaticResource PrimaryColorDark}}"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1"
                                                         VerticalOptions="Center"
                                                         Spacing="2">
                                        <Label Style="{StaticResource SerifH3}"
                                               Text="{Binding Nome}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Style="{StaticResource BodyMuted}"
                                               Text="{Binding Email}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Style="{StaticResource BodyMuted}"
                                               Text="{Binding Telefone}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
