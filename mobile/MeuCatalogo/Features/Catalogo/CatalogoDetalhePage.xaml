<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:catalogo="clr-namespace:MeuCatalogo.Features.Catalogo"
             x:Class="MeuCatalogo.Features.Catalogo.CatalogoDetalhePage"
             x:DataType="catalogo:CatalogoDetalhePageViewModel"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Hero -->
        <Border Grid.Row="0" Style="{StaticResource Hero}" HeightRequest="240">
            <Grid Padding="24,48,24,24" RowDefinitions="Auto,*,Auto">
                <Grid Grid.Row="0" ColumnDefinitions="44,*,44">
                    <Border Grid.Column="0"
                            Style="{StaticResource IconCircleSurface}"
                            HeightRequest="40"
                            WidthRequest="40">
                        <Label Text="‹"
                               FontSize="22"
                               FontFamily="LoraMedium"
                               TextColor="{AppThemeBinding Light={StaticResource TextColorLight}, Dark={StaticResource TextColorDark}}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding VoltarCommand}" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Label Grid.Column="1"
                           Text="DETALHE"
                           FontFamily="LatoBlack"
                           FontSize="11"
                           CharacterSpacing="6"
                           TextColor="{StaticResource OnPrimaryColor}"
                           Opacity="0.85"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Grid>

                <VerticalStackLayout Grid.Row="1" VerticalOptions="End" Spacing="2">
                    <Label Text="{Binding NomeCurto}"
                           FontFamily="LatoBold"
                           FontSize="11"
                           CharacterSpacing="3"
                           TextColor="{StaticResource OnPrimaryColor}"
                           Opacity="0.8"
                           IsVisible="{Binding NomeCurto, Converter={x:Static catalogo:NotNullOrEmptyConverter.Instance}}" />
                    <Label Text="{Binding Nome}"
                           FontFamily="LoraSemiBold"
                           FontSize="32"
                           LineHeight="1.05"
                           TextColor="{StaticResource OnPrimaryColor}"
                           LineBreakMode="WordWrap"
                           MaxLines="3" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,-32,20,24" Spacing="14">

                <!-- Stat card -->
                <Border Style="{StaticResource CardElevated}" Padding="20">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Style="{StaticResource Caps}" Text="PRODUTOS NESTE CATÁLOGO" />
                            <Label Style="{StaticResource SerifH1}"
                                   Text="{Binding TotalProdutos}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1"
                                Style="{StaticResource IconCircle}"
                                HeightRequest="48"
                                WidthRequest="48"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="24" />
                            </Border.StrokeShape>
                            <Label Text="›"
                                   FontFamily="LoraMedium"
                                   FontSize="22"
                                   TextColor="{StaticResource OnPrimaryColor}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding VerProdutosCommand}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>
                </Border>

                <!-- Contato -->
                <Border Style="{StaticResource Card}" Padding="20"
                        IsVisible="{Binding HasContato}">
                    <VerticalStackLayout Spacing="12">
                        <Label Style="{StaticResource Caps}" Text="CONTATO" />

                        <VerticalStackLayout Spacing="4"
                                             IsVisible="{Binding NumeroWhatsapp, Converter={x:Static catalogo:NotNullOrEmptyConverter.Instance}}">
                            <Label Style="{StaticResource FieldLabel}" Text="WHATSAPP" />
                            <Label Style="{StaticResource SerifH3}"
                                   Text="{Binding NumeroWhatsapp}" />
                        </VerticalStackLayout>

                        <BoxView Style="{StaticResource Divider}"
                                 IsVisible="{Binding Email, Converter={x:Static catalogo:NotNullOrEmptyConverter.Instance}}" />

                        <VerticalStackLayout Spacing="4"
                                             IsVisible="{Binding Email, Converter={x:Static catalogo:NotNullOrEmptyConverter.Instance}}">
                            <Label Style="{StaticResource FieldLabel}" Text="E-MAIL" />
                            <Label Style="{StaticResource SerifH3}"
                                   Text="{Binding Email}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Descrição -->
                <Border Style="{StaticResource Card}" Padding="20"
                        IsVisible="{Binding Descricao, Converter={x:Static catalogo:NotNullOrEmptyConverter.Instance}}">
                    <VerticalStackLayout Spacing="8">
                        <Label Style="{StaticResource Caps}" Text="SOBRE" />
                        <Label Style="{StaticResource SerifH3}" Text="A história" Margin="0,-2,0,0" />
                        <Label Text="{Binding Descricao}"
                               FontFamily="LatoRegular"
                               FontSize="14"
                               LineHeight="1.5"
                               Margin="0,4,0,0" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Sticky CTA -->
        <Border Grid.Row="2"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColorLight}, Dark={StaticResource SurfaceColorDark}}"
                Padding="20,12,20,18">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-4" Radius="12" Opacity="0.06" />
            </Border.Shadow>
            <Button Style="{StaticResource PrimaryButton}"
                    Text="VISUALIZAR COMO CLIENTE"
                    Command="{Binding VisualizarPublicaCommand}" />
        </Border>
    </Grid>
</ContentPage>
