<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:MeuCatalogo.Features.Catalogo"
             xmlns:components="clr-namespace:MeuCatalogo.Components"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="MeuCatalogo.Features.Catalogo.CatalogoAdicionarPage"
             x:DataType="viewmodel:CatalogoAdicionarPageViewModel">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,16,24,24" Spacing="20">

                <VerticalStackLayout Spacing="6">
                    <Label Style="{StaticResource Caps}" Text="ATELIÊ · CATÁLOGO" />
                    <Label Style="{StaticResource SerifH1}" Text="Novo catálogo" />
                    <Label Style="{StaticResource BodyMuted}"
                           Text="Crie a vitrine do seu ateliê. Seus clientes verão um catálogo público com este nome." />
                </VerticalStackLayout>

                <Border Style="{StaticResource Card}" Padding="20">
                    <VerticalStackLayout Spacing="0">
                        <Label Style="{StaticResource Caps}" Text="IDENTIFICAÇÃO" />
                        <Label Style="{StaticResource SerifH3}" Text="Como o catálogo se chama" Margin="0,2,0,4" />

                        <components:CustomEntry Title="NOME"
                                                Placeholder="Coleção Outono 2026"
                                                Text="{Binding Nome}"
                                                MaxLength="50"
                                                ErrorMessage="{Binding NomeErrorMessage}"
                                                HasError="{Binding NomeErrorMessage, Converter={toolkit:IsNotNullConverter}}" />

                        <components:CustomEntry Title="NOME CURTO"
                                                Placeholder="Outono 26"
                                                MaxLength="25"
                                                Text="{Binding NomeCurto}"
                                                ErrorMessage="{Binding NomeCurtoErrorMessage}"
                                                HasError="{Binding NomeCurtoErrorMessage, Converter={toolkit:IsNotNullConverter}}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource Card}" Padding="20">
                    <VerticalStackLayout Spacing="0">
                        <Label Style="{StaticResource Caps}" Text="CONTATO" />
                        <Label Style="{StaticResource SerifH3}" Text="Como falam com você" Margin="0,2,0,4" />

                        <components:CustomEntry Title="WHATSAPP"
                                                Placeholder="(11) 90000-0000"
                                                Text="{Binding NumeroWhatsapp}"
                                                Keyboard="Numeric"
                                                MaxLength="18"
                                                ErrorMessage="{Binding NumeroWhatsappErrorMessage}"
                                                HasError="{Binding NumeroWhatsappErrorMessage, Converter={toolkit:IsNotNullConverter}}" />

                        <components:CustomEntry Title="E-MAIL"
                                                Placeholder="contato@ateliê.com"
                                                Text="{Binding Email}"
                                                Keyboard="Email"
                                                ErrorMessage="{Binding EmailErrorMessage}"
                                                HasError="{Binding EmailErrorMessage, Converter={toolkit:IsNotNullConverter}}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Sticky save bar -->
        <Border Grid.Row="1"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColorLight}, Dark={StaticResource SurfaceColorDark}}"
                Padding="24,12,24,18">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-4" Radius="12" Opacity="0.06" />
            </Border.Shadow>
            <Button Style="{StaticResource PrimaryButton}"
                    Text="SALVAR CATÁLOGO"
                    Command="{Binding SalvarCommand}" />
        </Border>
    </Grid>
</ContentPage>
