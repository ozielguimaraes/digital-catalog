<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="MeuCatalogo.Features.Catalogo.CatalogoListaPage"
             xmlns:catalogo="clr-namespace:MeuCatalogo.Features.Catalogo"
             x:DataType="catalogo:CatalogoListaPageViewModel">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Image
                Source="ic_x_mark_circle_thin.png"
                HeightRequest="85"
                Margin="0,32,0,0"
                Aspect="AspectFit">
                <Image.Behaviors>
                    <toolkit:IconTintColorBehavior TintColor="{StaticResource Primary}" />
                </Image.Behaviors>
            </Image>

            <Label
                Text="Nenhum adicionado ainda!"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Clique no botão abaixo para adicionar"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Clique no botão abaixo para adicionar" />

            <Button
                Text="Adicionar Novo"
                SemanticProperties.Hint="Navega para tela de adicionar novo catálogo"
                HorizontalOptions="Fill"
                Command="{Binding AdicionarCommand}"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
