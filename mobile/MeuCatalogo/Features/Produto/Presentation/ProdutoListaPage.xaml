<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:converters="clr-namespace:MeuCatalogo.Converters"
             x:Class="MeuCatalogo.Features.Produto.ProdutoListaPage"
             x:Name="ProdutoListaPageRoot"
             xmlns:produto="clr-namespace:MeuCatalogo.Features.Produto"
             xmlns:domain="clr-namespace:MeuCatalogo.Features.Produto.Domain"
             x:DataType="produto:ProdutoListaPageViewModel">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            BindingContext="{Binding Source={x:Reference ProdutoListaPageRoot}, Path=BindingContext}"
            EventName="Appearing"
            Command="{Binding CarregarDadosCommand}" />
    </ContentPage.Behaviors>

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:IsNullOrWhiteSpaceConverter x:Key="IsNullOrWhiteSpaceConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="24,24,24,12" Spacing="6">
            <Label Style="{StaticResource Caps}" Text="ATELIÊ" />
            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                <Label Grid.Column="0"
                       Style="{StaticResource SerifH1}"
                       Text="Produtos" />
                <Border Grid.Column="1"
                        Style="{StaticResource IconCircle}"
                        IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"
                        IsVisible="{Binding HasProdutos}">
                    <Label Text="+"
                           FontFamily="LoraMedium"
                           FontSize="24"
                           TextColor="{StaticResource OnPrimaryColor}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding AdicionarCommand}" />
                    </Border.GestureRecognizers>
                </Border>
            </Grid>
        </VerticalStackLayout>

        <RefreshView Grid.Row="1"
                     Command="{Binding CarregarDadosCommand}"
                     IsRefreshing="{Binding IsRefreshing}">
            <ScrollView>
                <Grid Padding="24,8,24,32" RowDefinitions="Auto,Auto">

                    <!-- Loading -->
                    <VerticalStackLayout Grid.Row="0"
                                         IsVisible="{Binding IsSyncing}"
                                         VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Padding="0,48"
                                         Spacing="12">
                        <ActivityIndicator IsRunning="{Binding IsSyncing}"
                                           WidthRequest="36"
                                           HeightRequest="36" />
                        <Label Style="{StaticResource BodyMuted}"
                               HorizontalTextAlignment="Center"
                               Text="Carregando produtos…" />
                    </VerticalStackLayout>

                    <!-- Empty -->
                    <VerticalStackLayout Grid.Row="0"
                                         IsVisible="{Binding ShowEmptyState}"
                                         VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Padding="0,48"
                                         Spacing="12">
                        <Border Style="{StaticResource IconCircleSurface}"
                                HeightRequest="92"
                                WidthRequest="92"
                                HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="46" />
                            </Border.StrokeShape>
                            <Image Source="ic_x_mark_circle_thin.png"
                                   HeightRequest="44"
                                   Aspect="AspectFit">
                                <Image.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource PrimaryColorLight}, Dark={StaticResource PrimaryColorDark}}" />
                                </Image.Behaviors>
                            </Image>
                        </Border>

                        <Label Style="{StaticResource SerifH2}"
                               HorizontalTextAlignment="Center"
                               Text="Nenhum produto ainda" />
                        <Label Style="{StaticResource BodyMuted}"
                               HorizontalTextAlignment="Center"
                               Text="Adicione seu primeiro produto para começar a vender." />
                        <Button Style="{StaticResource PrimaryButton}"
                                Text="ADICIONAR PRODUTO"
                                HorizontalOptions="Center"
                                Margin="0,8,0,0"
                                Padding="32,14"
                                IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"
                                Command="{Binding AdicionarCommand}" />
                    </VerticalStackLayout>

                    <!-- Product list -->
                    <CollectionView Grid.Row="1"
                                    ItemsSource="{Binding Produtos}"
                                    SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="domain:ProdutoEntity">
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems Mode="Reveal">
                                            <SwipeItemView WidthRequest="92"
                                                           Command="{Binding Source={RelativeSource AncestorType={x:Type produto:ProdutoListaPageViewModel}}, Path=DeletarCommand}"
                                                           CommandParameter="{Binding .}">
                                                <Border Style="{StaticResource SwipeActionDanger}">
                                                    <VerticalStackLayout Padding="8"
                                                                         HorizontalOptions="Center"
                                                                         VerticalOptions="Center"
                                                                         Spacing="4">
                                                        <Image Source="ic_trash_can_outlined.png"
                                                               HeightRequest="22"
                                                               WidthRequest="22"
                                                               HorizontalOptions="Center">
                                                            <Image.Behaviors>
                                                                <toolkit:IconTintColorBehavior TintColor="{StaticResource OnPrimaryColor}" />
                                                            </Image.Behaviors>
                                                        </Image>
                                                        <Label Text="Excluir"
                                                               FontFamily="LatoBold"
                                                               FontSize="11"
                                                               TextColor="{StaticResource OnPrimaryColor}"
                                                               HorizontalTextAlignment="Center" />
                                                    </VerticalStackLayout>
                                                </Border>
                                            </SwipeItemView>
                                        </SwipeItems>
                                    </SwipeView.RightItems>

                                    <Border Style="{StaticResource CardElevated}" Padding="0">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type produto:ProdutoListaPageViewModel}}, Path=EditarCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>

                                        <Grid ColumnDefinitions="84,*" ColumnSpacing="0" Padding="12">
                                            <!-- Thumbnail -->
                                            <Grid Grid.Column="0" WidthRequest="84" HeightRequest="84">
                                                <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceMutedColorLight}, Dark={StaticResource SurfaceMutedColorDark}}"
                                                        StrokeThickness="0"
                                                        IsVisible="{Binding ThumbnailUrl, Converter={StaticResource IsNullOrWhiteSpaceConverter}}">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="12" />
                                                    </Border.StrokeShape>
                                                    <Image Source="ic_x_mark_circle_thin.png"
                                                           Aspect="Center"
                                                           WidthRequest="32"
                                                           HeightRequest="32">
                                                        <Image.Behaviors>
                                                            <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource TextMutedColorLight}, Dark={StaticResource TextMutedColorDark}}" />
                                                        </Image.Behaviors>
                                                    </Image>
                                                </Border>

                                                <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceMutedColorLight}, Dark={StaticResource SurfaceMutedColorDark}}"
                                                        StrokeThickness="0"
                                                        IsVisible="{Binding ThumbnailUrl, Converter={toolkit:IsStringNotNullOrEmptyConverter}}">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="12" />
                                                    </Border.StrokeShape>
                                                    <Image Aspect="AspectFill">
                                                        <Image.Source>
                                                            <UriImageSource Uri="{Binding ThumbnailUrl}" CacheValidity="1.00:00:00" />
                                                        </Image.Source>
                                                    </Image>
                                                </Border>
                                            </Grid>

                                            <VerticalStackLayout Grid.Column="1"
                                                                 Padding="14,0,4,0"
                                                                 VerticalOptions="Center"
                                                                 Spacing="6">
                                                <Label Style="{StaticResource Caps}"
                                                       Text="{Binding CategoriaNome}"
                                                       IsVisible="{Binding CategoriaNome, Converter={toolkit:IsStringNotNullOrEmptyConverter}}" />

                                                <Label Style="{StaticResource SerifH3}"
                                                       Text="{Binding Nome}"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="2" />

                                                <HorizontalStackLayout Spacing="8">
                                                    <Label Text="{Binding PrecoComDesconto, StringFormat='{0:C}'}"
                                                           FontFamily="LatoBold"
                                                           FontSize="15"
                                                           TextColor="{AppThemeBinding Light={StaticResource PrimaryHoverColorLight}, Dark={StaticResource PrimaryColorDark}}"
                                                           IsVisible="True">
                                                        <Label.Triggers>
                                                            <DataTrigger TargetType="Label" Binding="{Binding PrecoComDesconto}" Value="{x:Null}">
                                                                <Setter Property="IsVisible" Value="False" />
                                                            </DataTrigger>
                                                            <DataTrigger TargetType="Label" Binding="{Binding PrecoComDesconto}" Value="0">
                                                                <Setter Property="IsVisible" Value="False" />
                                                            </DataTrigger>
                                                        </Label.Triggers>
                                                    </Label>

                                                    <Label Text="{Binding Preco, StringFormat='{0:C}'}"
                                                           FontFamily="LatoBold"
                                                           FontSize="15"
                                                           TextColor="{AppThemeBinding Light={StaticResource PrimaryHoverColorLight}, Dark={StaticResource PrimaryColorDark}}"
                                                           IsVisible="False">
                                                        <Label.Triggers>
                                                            <DataTrigger TargetType="Label" Binding="{Binding PrecoComDesconto}" Value="{x:Null}">
                                                                <Setter Property="IsVisible" Value="True" />
                                                            </DataTrigger>
                                                            <DataTrigger TargetType="Label" Binding="{Binding PrecoComDesconto}" Value="0">
                                                                <Setter Property="IsVisible" Value="True" />
                                                            </DataTrigger>
                                                        </Label.Triggers>
                                                    </Label>

                                                    <Label Text="{Binding Preco, StringFormat='{0:C}'}"
                                                           FontFamily="LatoRegular"
                                                           FontSize="12"
                                                           TextColor="{AppThemeBinding Light={StaticResource TextMutedColorLight}, Dark={StaticResource TextMutedColorDark}}"
                                                           TextDecorations="Strikethrough"
                                                           VerticalOptions="Center"
                                                           IsVisible="True">
                                                        <Label.Triggers>
                                                            <DataTrigger TargetType="Label" Binding="{Binding PrecoComDesconto}" Value="{x:Null}">
                                                                <Setter Property="IsVisible" Value="False" />
                                                            </DataTrigger>
                                                            <DataTrigger TargetType="Label" Binding="{Binding PrecoComDesconto}" Value="0">
                                                                <Setter Property="IsVisible" Value="False" />
                                                            </DataTrigger>
                                                        </Label.Triggers>
                                                    </Label>
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </ScrollView>
        </RefreshView>

        <!-- Busy overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="2"
              BackgroundColor="#A0121212"
              IsVisible="{Binding IsBusy}">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               Color="{StaticResource OnPrimaryColor}"
                               WidthRequest="48"
                               HeightRequest="48"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
        </Grid>
    </Grid>
</ContentPage>
