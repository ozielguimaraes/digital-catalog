<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MeuCatalogo.Features.Auth.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModel="clr-namespace:MeuCatalogo.Features.Auth"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:DataType="viewModel:LoginPageViewModel">

    <Grid>
        <ScrollView>
            <Grid RowDefinitions="320,*" Padding="0">

                <!-- Hero -->
                <Border Grid.Row="0" Style="{StaticResource Hero}">
                    <Grid Padding="32,56,32,32" RowDefinitions="Auto,*,Auto">
                        <Label Grid.Row="0"
                               Text="SANY&amp;Z"
                               FontFamily="LatoBlack"
                               FontSize="14"
                               TextColor="{StaticResource OnPrimaryColor}"
                               Opacity="0.85"
                               CharacterSpacing="6" />
                        <VerticalStackLayout Grid.Row="1" VerticalOptions="Center" Spacing="6">
                            <Label Text="Bem-vinda"
                                   TextColor="{StaticResource OnPrimaryColor}"
                                   FontFamily="LoraMediumItalic"
                                   FontSize="40"
                                   LineHeight="1.05" />
                            <Label Text="de volta ao ateliê."
                                   TextColor="{StaticResource OnPrimaryColor}"
                                   FontFamily="LoraMedium"
                                   FontSize="40"
                                   LineHeight="1.05" />
                        </VerticalStackLayout>
                        <Label Grid.Row="2"
                               Text="LEVE COM VOCÊ"
                               FontFamily="LatoBold"
                               FontSize="11"
                               TextColor="{StaticResource OnPrimaryColor}"
                               Opacity="0.8"
                               CharacterSpacing="4" />
                    </Grid>
                </Border>

                <!-- Form card -->
                <Border Grid.Row="1"
                        Style="{StaticResource CardElevated}"
                        Margin="20,-32,20,24"
                        Padding="28,32">
                    <VerticalStackLayout Spacing="20">

                        <VerticalStackLayout Spacing="6">
                            <Label Style="{StaticResource Caps}" Text="ENTRAR" />
                            <Label Style="{StaticResource SerifH1}" Text="Acesse sua conta" />
                            <Label Style="{StaticResource BodyMuted}"
                                   Text="Use seu e-mail e senha para continuar gerenciando seus catálogos." />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Style="{StaticResource FieldLabel}" Text="E-MAIL" />
                            <Border Style="{StaticResource PillEntryHost}">
                                <Entry Text="{Binding Email}"
                                       Placeholder="seu@email.com"
                                       Keyboard="Email"
                                       ReturnType="Next"
                                       BackgroundColor="Transparent"
                                       Margin="14,4" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Style="{StaticResource FieldLabel}" Text="SENHA" />
                            <Border Style="{StaticResource PillEntryHost}">
                                <Entry Text="{Binding Password}"
                                       Placeholder="••••••••"
                                       MaxLength="50"
                                       IsPassword="True"
                                       ReturnType="Done"
                                       BackgroundColor="Transparent"
                                       Margin="14,4" />
                            </Border>
                        </VerticalStackLayout>

                        <Button x:Name="loginButton"
                                Style="{StaticResource PrimaryButton}"
                                Text="ENTRAR"
                                IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"
                                Command="{Binding LoginCommand}" />

                        <Label HorizontalOptions="Center"
                               Padding="0,4,0,0"
                               FontSize="14">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Não possui uma conta?  "
                                          TextColor="{AppThemeBinding Light={StaticResource TextMutedColorLight}, Dark={StaticResource TextMutedColorDark}}"
                                          FontFamily="LatoRegular" />
                                    <Span Text="Cadastrar"
                                          FontFamily="LatoBold"
                                          TextColor="{AppThemeBinding Light={StaticResource PrimaryHoverColorLight}, Dark={StaticResource PrimaryColorDark}}"
                                          TextDecorations="Underline" />
                                </FormattedString>
                            </Label.FormattedText>
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CreateAccountCommand}" NumberOfTapsRequired="1" />
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </ScrollView>

        <!-- Busy overlay -->
        <Grid BackgroundColor="#A0121212"
              IsVisible="{Binding IsBusy}">
            <VerticalStackLayout HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="14">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   Color="{StaticResource OnPrimaryColor}"
                                   WidthRequest="48"
                                   HeightRequest="48" />
                <Label Text="{Binding BusyMessage}"
                       TextColor="{StaticResource OnPrimaryColor}"
                       FontFamily="LatoRegular"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
