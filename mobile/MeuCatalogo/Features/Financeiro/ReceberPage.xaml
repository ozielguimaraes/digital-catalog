<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:financeiro="clr-namespace:MeuCatalogo.Features.Financeiro"
             x:Class="MeuCatalogo.Features.Financeiro.ReceberPage"
             x:DataType="financeiro:ReceberPageViewModel"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <VerticalStackLayout Grid.Row="0" Padding="24,48,24,12" Spacing="6">
            <Grid ColumnDefinitions="40,*,40">
                <Border Grid.Column="0"
                        Style="{StaticResource IconCircleSurface}"
                        HeightRequest="40"
                        WidthRequest="40">
                    <Label Text="‹"
                           FontSize="22"
                           FontFamily="LoraMedium"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding VoltarCommand}" />
                    </Border.GestureRecognizers>
                </Border>
            </Grid>
            <Label Style="{StaticResource Caps}" Text="FINANCEIRO" />
            <Label Style="{StaticResource SerifH1}" Text="A receber" />
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <financeiro:LancamentoListView Margin="24,8,24,32"
                                           Lancamentos="{Binding Lancamentos}" />
        </ScrollView>
    </Grid>
</ContentPage>
