<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:financeiro="clr-namespace:MeuCatalogo.Features.Financeiro"
             xmlns:domain="clr-namespace:MeuCatalogo.Features.Financeiro.Domain"
             x:Class="MeuCatalogo.Features.Financeiro.RecorrenciasPage"
             x:DataType="financeiro:RecorrenciasPageViewModel"
             Title="Recorrências">
    <Grid RowDefinitions="*" Padding="16">
        <RefreshView Command="{Binding CarregarCommand}" IsRefreshing="{Binding IsLoading}">
            <CollectionView ItemsSource="{Binding Recorrencias}" SelectionMode="None"
                            EmptyView="Nenhuma recorrência cadastrada">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="domain:RecorrenciaInfo">
                        <Border Padding="14" Margin="0,0,0,8" StrokeShape="RoundRectangle 12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Descricao}" FontSize="15" FontAttributes="Bold" />
                                <Label Text="{Binding ValorLabel}" FontSize="13" />
                                <Label Text="{Binding PeriodicidadeLabel}" FontSize="12" Opacity="0.7" />
                                <Label Text="{Binding ProximaData, StringFormat='Próxima: {0:dd/MM/yyyy}'}"
                                       FontSize="12" Opacity="0.7" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
