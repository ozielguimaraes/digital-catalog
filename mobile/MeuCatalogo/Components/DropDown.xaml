<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:MeuCatalogo.Components"
             x:Class="MeuCatalogo.Components.DropDown"
             x:Name="View"
             x:DataType="components:DropDown">

    <Grid RowDefinitions="Auto, Auto" Margin="0,8,0,0">
        <Label Text="{Binding Title}" />

        <Border BackgroundColor="{StaticResource Gray100}" Padding="12" GestureRecognizers="{StaticResource TapGesture}">
            <HorizontalStackLayout>
                <Label Text="{Binding SelectedItem.DisplayText}" />
                <Image Source="arrow_down.png" HorizontalOptions="EndAndExpand"/>
            </HorizontalStackLayout>
        </Border>

        <Label Grid.Row="1"
               Text="{Binding ErrorMessage}"
               TextColor="Red"
               IsVisible="{Binding HasError}" />
    </Grid>
</ContentView>
