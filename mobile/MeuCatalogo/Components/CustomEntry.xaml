<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MeuCatalogo.Components.CustomEntry"
             x:Name="CustomEntryRoot">
    <VerticalStackLayout Spacing="2">
        <Label x:Name="TitleLabel"
               FontAttributes="Bold"
               Margin="0,8,0,0"
               Text="{Binding Title, Source={x:Reference CustomEntryRoot}}"/>
        <Entry x:Name="EntryField"
               x:FieldModifier="public"
               Placeholder="{Binding Title}"
               Text="{Binding Source={x:Reference CustomEntryRoot}, Path=Text, Mode=TwoWay}"
               Keyboard="{Binding Source={x:Reference CustomEntryRoot}, Path=Keyboard}"
               ReturnType="{Binding Source={x:Reference CustomEntryRoot}, Path=ReturnType}"
               MaxLength="{Binding Source={x:Reference CustomEntryRoot}, Path=MaxLength}"
               IsPassword="{Binding Source={x:Reference CustomEntryRoot}, Path=IsPassword}"
               ReturnCommand="{Binding Source={x:Reference CustomEntryRoot}, Path=ReturnCommand}"/>
        <Label x:Name="ErrorLabel"
               Text="{Binding ErrorMessage, Source={x:Reference CustomEntryRoot}}"
               TextColor="Red"
               IsVisible="{Binding HasError, Source={x:Reference CustomEntryRoot}}"/>
    </VerticalStackLayout>
</ContentView>
