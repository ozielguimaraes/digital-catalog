<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MeuCatalogo.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:catalogo="clr-namespace:MeuCatalogo.Features.Catalogo"
    xmlns:produto="clr-namespace:MeuCatalogo.Features.Produto"
    xmlns:vm="clr-namespace:MeuCatalogo"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Shell.FlyoutBehavior="Flyout"
    x:DataType="vm:AppShellViewModel"
    Title="Sany&amp;Z">

    <Shell.FlyoutHeaderTemplate>
        <DataTemplate>
            <Border StrokeThickness="0"
                    Background="{StaticResource PrimaryGradientBrush}"
                    HeightRequest="180">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="0,0,32,32" />
                </Border.StrokeShape>
                <Grid Padding="24,32,24,24" RowDefinitions="Auto,*,Auto">
                    <Label Grid.Row="0"
                           Text="SANY&amp;Z"
                           FontFamily="LatoBlack"
                           FontSize="11"
                           CharacterSpacing="6"
                           TextColor="{StaticResource OnPrimaryColor}"
                           Opacity="0.85" />
                    <VerticalStackLayout Grid.Row="1"
                                         VerticalOptions="End"
                                         Spacing="2">
                        <Label Text="Olá,"
                               FontFamily="LoraMediumItalic"
                               FontSize="22"
                               TextColor="{StaticResource OnPrimaryColor}" />
                        <Label Text="{Binding UserDisplayName}"
                               FontFamily="LoraSemiBold"
                               FontSize="26"
                               TextColor="{StaticResource OnPrimaryColor}"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                    <Label Grid.Row="2"
                           Text="LEVE COM VOCÊ"
                           FontFamily="LatoBold"
                           FontSize="10"
                           CharacterSpacing="4"
                           TextColor="{StaticResource OnPrimaryColor}"
                           Opacity="0.75"
                           Margin="0,12,0,0" />
                </Grid>
            </Border>
        </DataTemplate>
    </Shell.FlyoutHeaderTemplate>

    <ShellContent
        Title="Produtos"
        ContentTemplate="{DataTemplate produto:ProdutoListaPage}"
        Route="ProdutoListaPage" />

    <ShellContent
        Title="Catálogos"
        ContentTemplate="{DataTemplate catalogo:CatalogoListaPage}"
        Route="CatalogoListaPage" />

    <Shell.FlyoutFooterTemplate>
        <DataTemplate>
            <VerticalStackLayout Padding="20,16,20,24" Spacing="12">
                <Border Style="{StaticResource Card}" Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Style="{StaticResource Caps}" Text="CONTA" />
                        <Label Text="{Binding Email}"
                               FontFamily="LatoRegular"
                               FontSize="13"
                               LineBreakMode="TailTruncation" />
                        <BoxView Style="{StaticResource Divider}" Margin="0,4" />
                        <Grid ColumnDefinitions="Auto,*">
                            <Label Grid.Column="0" Style="{StaticResource Caps}" Text="VERSÃO" />
                            <Label Grid.Column="1"
                                   Text="{Binding VersionName}"
                                   FontFamily="LatoRegular"
                                   FontSize="11"
                                   HorizontalOptions="End"
                                   TextColor="{AppThemeBinding Light={StaticResource TextMutedColorLight}, Dark={StaticResource TextMutedColorDark}}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceMutedColorLight}, Dark={StaticResource SurfaceMutedColorDark}}"
                        Padding="14,12">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="20,*" ColumnSpacing="12">
                        <Image Grid.Column="0"
                               Source="ic_logout.png"
                               WidthRequest="18"
                               HeightRequest="18"
                               VerticalOptions="Center">
                            <Image.Behaviors>
                                <toolkit:IconTintColorBehavior TintColor="{StaticResource DangerColor}" />
                            </Image.Behaviors>
                        </Image>
                        <Label Grid.Column="1"
                               Text="Sair"
                               FontFamily="LatoBold"
                               FontSize="14"
                               TextColor="{StaticResource DangerColor}"
                               VerticalTextAlignment="Center" />
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </DataTemplate>
    </Shell.FlyoutFooterTemplate>
</Shell>
