<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
    ⚠️ DEPRECATED keys — kept for backwards compatibility with pages that
    still reference Primary/Secondary/Magenta/MidnightBlue/OffBlack/Gray*.

    For new code, use the semantic tokens declared in BrandColors.xaml:
        Primary*, Secondary*, Background*, Surface*, SurfaceMuted*,
        Text*, TextMuted*, Border*, BorderSubtle*,
        Success*, Warning*, Danger*, OnPrimary*

    Hex values below mirror the light-theme value of the semantic token
    they replace. If you change the brand, update BrandColors.xaml AND
    re-sync these legacy aliases from the new light-theme values.
    -->

    <!-- maps to PrimaryColorLight -->
    <Color x:Key="Primary">#c06647</Color>
    <!-- maps to PrimaryColorDark (used in dark theme) -->
    <Color x:Key="PrimaryDark">#df8252</Color>
    <!-- maps to TextColorLight -->
    <Color x:Key="PrimaryDarkText">#332a27</Color>
    <!-- maps to SurfaceMutedColorLight -->
    <Color x:Key="Secondary">#dfd5ce</Color>
    <!-- maps to SecondaryColorLight -->
    <Color x:Key="SecondaryDarkText">#df8252</Color>
    <!-- maps to PrimaryHoverColorLight -->
    <Color x:Key="Tertiary">#8a472a</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <!-- legacy validation accent → maps to DangerColor -->
    <Color x:Key="Magenta">#8a3a3a</Color>
    <!-- legacy heading color → maps to TextColorLight -->
    <Color x:Key="MidnightBlue">#332a27</Color>
    <!-- legacy dark page bg → maps to BackgroundColorDark -->
    <Color x:Key="OffBlack">#121212</Color>

    <!-- Warm neutral scale (kept for borders/disabled states; mirrors semantic equivalents) -->
    <Color x:Key="Gray">#ede8e2</Color>             <!-- SurfaceMutedColorLight -->
    <Color x:Key="Gray100">#faf6f1</Color>
    <Color x:Key="Gray200">#dfd5ce</Color>          <!-- BrandQuartz / borders -->
    <Color x:Key="Gray300">#c4b8ac</Color>
    <Color x:Key="Gray400">#a89a8e</Color>          <!-- TextMutedColorDark -->
    <Color x:Key="Gray500">#7a6a60</Color>          <!-- TextMutedColorLight -->
    <Color x:Key="Gray600">#5a4d44</Color>
    <Color x:Key="Gray900">#332a27</Color>          <!-- TextColorLight -->
    <Color x:Key="Gray950">#1a1614</Color>

    <SolidColorBrush x:Key="PrimaryBrushLegacy" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}" />
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}" />
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}" />

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}" />
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}" />
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}" />
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}" />
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}" />
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}" />
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}" />
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}" />
</ResourceDictionary>
