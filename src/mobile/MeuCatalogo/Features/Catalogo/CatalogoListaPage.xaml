<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="MeuCatalogo.Features.Catalogo.CatalogoListaPage"
             xmlns:catalogo="clr-namespace:MeuCatalogo.Features.Catalogo"
             xmlns:domain="clr-namespace:MeuCatalogo.Features.Catalogo.Domain"
             xmlns:fonts="clr-namespace:MeuCatalogo.Resources.Fonts"
             x:DataType="catalogo:CatalogoListaPageViewModel">

    <Shell.TitleView>
        <VerticalStackLayout VerticalOptions="Center" Spacing="0">
            <Label Style="{StaticResource Caps}" Text="ATELIÊ" />
            <Label Text="Seus catálogos" FontFamily="LoraMedium" FontSize="18" />
        </VerticalStackLayout>
    </Shell.TitleView>

    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding AdicionarCommand}">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="{x:Static fonts:FluentUI.FontFamily}"
                                 Glyph="{x:Static fonts:FluentUI.add_24_regular}"
                                 Color="{AppThemeBinding Light={StaticResource BrandCopperSany}, Dark={StaticResource BrandCopperZ}}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <ScrollView>
        <Grid Padding="24,16,24,32" RowDefinitions="Auto,Auto">

                <!-- Loading -->
                <VerticalStackLayout Grid.Row="0"
                                     IsVisible="{Binding IsSyncing}"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Padding="0,48"
                                     Spacing="12">
                    <ActivityIndicator IsRunning="{Binding IsSyncing}"
                                       WidthRequest="36"
                                       HeightRequest="36" />
                    <Label Style="{StaticResource BodyMuted}"
                           HorizontalTextAlignment="Center"
                           Text="Carregando seus catálogos…" />
                </VerticalStackLayout>

                <!-- Empty state -->
                <VerticalStackLayout Grid.Row="0"
                                     IsVisible="{Binding ShowEmptyState}"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Padding="0,48"
                                     Spacing="12">
                    <Border Style="{StaticResource IconCircleSurface}"
                            HeightRequest="92"
                            WidthRequest="92"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="46" />
                        </Border.StrokeShape>
                        <Image Source="ic_x_mark_circle_thin.png"
                               HeightRequest="44"
                               Aspect="AspectFit">
                            <Image.Behaviors>
                                <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource PrimaryColorLight}, Dark={StaticResource PrimaryColorDark}}" />
                            </Image.Behaviors>
                        </Image>
                    </Border>

                    <Label Style="{StaticResource SerifH2}"
                           HorizontalTextAlignment="Center"
                           Text="Nenhum catálogo ainda" />
                    <Label Style="{StaticResource BodyMuted}"
                           HorizontalTextAlignment="Center"
                           Text="Crie seu primeiro catálogo para começar a organizar produtos." />
                    <Button Style="{StaticResource PrimaryButton}"
                            Text="CRIAR CATÁLOGO"
                            HorizontalOptions="Center"
                            Margin="0,8,0,0"
                            Padding="32,14"
                            Command="{Binding AdicionarCommand}" />
                </VerticalStackLayout>

                <!-- Catalog list -->
                <CollectionView Grid.Row="1"
                                ItemsSource="{Binding Catalogos}"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="domain:CatalogoInfo">
                            <SwipeView>
                                <SwipeView.LeftItems>
                                    <SwipeItems Mode="Reveal">
                                        <SwipeItemView WidthRequest="92">
                                            <Border Style="{StaticResource SwipeActionWarning}">
                                                <VerticalStackLayout Padding="8"
                                                                     HorizontalOptions="Center"
                                                                     VerticalOptions="Center"
                                                                     Spacing="4">
                                                    <Label Text="{x:Static fonts:FluentUI.bookmark_24_regular}"
                                                           FontFamily="{x:Static fonts:FluentUI.FontFamily}"
                                                           FontSize="22"
                                                           TextColor="{StaticResource OnPrimaryColor}"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center" />
                                                    <Label Text="Usar"
                                                           FontFamily="LatoBold"
                                                           FontSize="11"
                                                           TextColor="{StaticResource OnPrimaryColor}"
                                                           HorizontalTextAlignment="Center" />
                                                </VerticalStackLayout>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding BindingContext.UsarCommand, Source={RelativeSource AncestorType={x:Type catalogo:CatalogoListaPage}}}"
                                                                          CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                            </Border>
                                        </SwipeItemView>
                                    </SwipeItems>
                                </SwipeView.LeftItems>
                                <SwipeView.RightItems>
                                    <SwipeItems Mode="Reveal">
                                        <SwipeItemView WidthRequest="92">
                                            <Border Style="{StaticResource SwipeActionDanger}">
                                                <VerticalStackLayout Padding="8"
                                                                     HorizontalOptions="Center"
                                                                     VerticalOptions="Center"
                                                                     Spacing="4">
                                                    <Label Text="{x:Static fonts:FluentUI.delete_24_regular}"
                                                           FontFamily="{x:Static fonts:FluentUI.FontFamily}"
                                                           FontSize="22"
                                                           TextColor="{StaticResource OnPrimaryColor}"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center" />
                                                    <Label Text="Excluir"
                                                           FontFamily="LatoBold"
                                                           FontSize="11"
                                                           TextColor="{StaticResource OnPrimaryColor}"
                                                           HorizontalTextAlignment="Center" />
                                                </VerticalStackLayout>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding BindingContext.ExcluirCommand, Source={RelativeSource AncestorType={x:Type catalogo:CatalogoListaPage}}}"
                                                                          CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                            </Border>
                                        </SwipeItemView>
                                    </SwipeItems>
                                </SwipeView.RightItems>

                                <Border Style="{StaticResource CardElevated}" Padding="0">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding BindingContext.VerDetalheCommand, Source={RelativeSource AncestorType={x:Type catalogo:CatalogoListaPage}}}"
                                                              CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="6,*" RowDefinitions="*">
                                        <BoxView Grid.Column="0"
                                                 BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryColorLight}, Dark={StaticResource PrimaryColorDark}}" />
                                        <VerticalStackLayout Grid.Column="1"
                                                             Padding="18,16"
                                                             Spacing="6">
                                            <Label Style="{StaticResource Caps}"
                                                   Text="{Binding NomeCurto}"
                                                   IsVisible="{Binding NomeCurto, Converter={toolkit:IsStringNotNullOrEmptyConverter}}" />
                                            <Label Style="{StaticResource SerifH3}"
                                                   Text="{Binding Nome}"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2" />
                                            <HorizontalStackLayout Spacing="14"
                                                                   Margin="0,4,0,0">
                                                <Label Style="{StaticResource BodyMuted}"
                                                       Text="{Binding Email}"
                                                       LineBreakMode="TailTruncation"
                                                       IsVisible="{Binding Email, Converter={toolkit:IsStringNotNullOrEmptyConverter}}" />
                                            </HorizontalStackLayout>
                                            <Label Style="{StaticResource BodyMuted}"
                                                   Text="{Binding NumeroWhatsapp, StringFormat='WhatsApp · {0}'}"
                                                   IsVisible="{Binding NumeroWhatsapp, Converter={toolkit:IsStringNotNullOrEmptyConverter}}" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
        </Grid>
    </ScrollView>
</ContentPage>
