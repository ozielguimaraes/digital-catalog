<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:cliente="clr-namespace:MeuCatalogo.Features.Cliente"
             xmlns:components="clr-namespace:MeuCatalogo.Components"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="MeuCatalogo.Features.Cliente.ClienteUpsertPage"
             x:DataType="cliente:ClienteUpsertPageViewModel">

    <Shell.TitleView>
        <VerticalStackLayout VerticalOptions="Center" Spacing="0">
            <Label Style="{StaticResource Caps}" Text="ATELIÊ · CRM" />
            <Label Text="{Binding Titulo}" FontFamily="LoraMedium" FontSize="18" />
        </VerticalStackLayout>
    </Shell.TitleView>

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,16,24,24" Spacing="20">

                <Label Style="{StaticResource BodyMuted}"
                       Text="Cadastre os dados de contato do seu cliente." />

                <Border Style="{StaticResource Card}" Padding="20">
                    <VerticalStackLayout Spacing="0">
                        <Label Style="{StaticResource Caps}" Text="IDENTIFICAÇÃO" />
                        <Label Style="{StaticResource SerifH3}" Text="Quem é o cliente" Margin="0,2,0,4" />

                        <components:CustomEntry Title="NOME"
                                                Placeholder="Nome completo"
                                                Text="{Binding Nome}"
                                                MaxLength="100"
                                                ReturnType="Next"
                                                ErrorMessage="{Binding NomeErrorMessage}"
                                                HasError="{Binding NomeErrorMessage, Converter={toolkit:IsNotNullConverter}}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource Card}" Padding="20">
                    <VerticalStackLayout Spacing="0">
                        <Label Style="{StaticResource Caps}" Text="CONTATO" />
                        <Label Style="{StaticResource SerifH3}" Text="Como falar com o cliente" Margin="0,2,0,4" />

                        <components:CustomEntry Title="TELEFONE"
                                                Placeholder="(11) 90000-0000"
                                                Text="{Binding Telefone}"
                                                Keyboard="Numeric"
                                                Mask="(XX) XXXXX-XXXX"
                                                MaxLength="16"
                                                ReturnType="Next" />

                        <components:CustomEntry Title="E-MAIL"
                                                Placeholder="cliente@email.com"
                                                Text="{Binding Email}"
                                                Keyboard="Email"
                                                MaxLength="120"
                                                ReturnType="Next"
                                                ErrorMessage="{Binding EmailErrorMessage}"
                                                HasError="{Binding EmailErrorMessage, Converter={toolkit:IsNotNullConverter}}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource Card}" Padding="20">
                    <VerticalStackLayout Spacing="0">
                        <Label Style="{StaticResource Caps}" Text="OBSERVAÇÕES" />
                        <Label Style="{StaticResource SerifH3}" Text="Notas internas" Margin="0,2,0,4" />

                        <components:CustomEntry Title="INFORMAÇÕES ADICIONAIS"
                                                Placeholder="Preferências, endereço, anotações…"
                                                Text="{Binding InformacoesAdicionais}"
                                                MaxLength="500"
                                                ReturnType="Done"
                                                ReturnCommand="{Binding SalvarCommand}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceColorLight}, Dark={StaticResource SurfaceColorDark}}"
                Padding="24,12,24,18">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-4" Radius="12" Opacity="0.06" />
            </Border.Shadow>
            <Button Style="{StaticResource PrimaryButton}"
                    Text="SALVAR CLIENTE"
                    IsEnabled="{Binding IsSaving, Converter={toolkit:InvertedBoolConverter}}"
                    Command="{Binding SalvarCommand}" />
        </Border>

        <Grid Grid.Row="0" Grid.RowSpan="2"
              BackgroundColor="#A0121212"
              IsVisible="{Binding IsSaving}">
            <ActivityIndicator IsRunning="{Binding IsSaving}"
                               Color="{StaticResource OnPrimaryColor}"
                               WidthRequest="48"
                               HeightRequest="48"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
        </Grid>
    </Grid>
</ContentPage>
