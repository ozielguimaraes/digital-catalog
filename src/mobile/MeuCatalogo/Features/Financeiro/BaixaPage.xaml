<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:financeiro="clr-namespace:MeuCatalogo.Features.Financeiro"
             x:Class="MeuCatalogo.Features.Financeiro.BaixaPage"
             x:DataType="financeiro:BaixaPageViewModel"
             Title="Registrar baixa">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">
            <Label Text="{Binding LancamentoDescricao}" FontSize="14" Opacity="0.7" />
            <Label Text="{Binding ValorEmAberto, StringFormat='Em aberto: {0:C}'}" FontSize="13" />

            <Label Text="Valor da baixa" />
            <Entry Text="{Binding Valor}" Keyboard="Numeric" />
            <Label Text="Data" />
            <DatePicker Date="{Binding Data}" />
            <Label Text="Conta" />
            <Picker ItemsSource="{Binding Contas}" ItemDisplayBinding="{Binding Nome}" SelectedItem="{Binding ContaSelecionada}" />
            <Label Text="Observações" />
            <Editor Text="{Binding Observacoes}" HeightRequest="80" />
            <Button Text="Registrar baixa" Command="{Binding SalvarCommand}" Margin="0,16,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
