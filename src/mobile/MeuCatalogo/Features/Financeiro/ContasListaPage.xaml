<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:financeiro="clr-namespace:MeuCatalogo.Features.Financeiro"
             xmlns:domain="clr-namespace:MeuCatalogo.Features.Financeiro.Domain"
             x:Class="MeuCatalogo.Features.Financeiro.ContasListaPage"
             x:DataType="financeiro:ContasListaPageViewModel"
             Title="Contas">
    <Grid RowDefinitions="*,Auto" Padding="16">
        <RefreshView Grid.Row="0" Command="{Binding CarregarCommand}" IsRefreshing="{Binding IsLoading}">
            <CollectionView ItemsSource="{Binding Contas}"
                            SelectionMode="None"
                            EmptyView="Nenhuma conta cadastrada">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="domain:ContaInfo">
                        <Border Padding="14" Margin="0,0,0,10" StrokeShape="RoundRectangle 12">
                            <Grid ColumnDefinitions="6,*,Auto">
                                <BoxView Grid.Column="0" WidthRequest="6" Color="{Binding Cor}" />
                                <VerticalStackLayout Grid.Column="1" Padding="12,0,0,0" Spacing="2">
                                    <Label Text="{Binding Nome}" FontSize="16" FontAttributes="Bold" />
                                    <Label Text="{Binding TipoLabel}" FontSize="12" Opacity="0.7" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="{Binding Limite, StringFormat='Limite {0:C}'}"
                                       FontSize="12" Opacity="0.7" VerticalOptions="Center"
                                       IsVisible="{Binding EhCartaoCredito}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
        <Button Grid.Row="1" Text="+ Nova conta" Command="{Binding NovaContaCommand}" Margin="0,12,0,0" />
    </Grid>
</ContentPage>
